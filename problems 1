<!DOCTYPE html>
<html>
<body>

<h2>Password Show / Hide</h2>

<input type="password" id="pass">

<button onclick="showPassword()">Show Password</button>

<script>
function showPassword() {
  var x = document.getElementById("pass");
  if (x.type === "password") {
    x.type = "text";
  } else {
    x.type = "password";
  }
}
</script>

</body>
</html>
