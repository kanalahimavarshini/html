int detectLoop(struct node *head){
    struct node *slow=head;
    struct node *fast=head;

    while(slow && fast && fast->next){
        slow=slow->next;
        fast=fast->next->next;

        if(slow==fast)
            return 1;
    }

    return 0;
}

