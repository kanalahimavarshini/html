struct node{
    int data;
    struct node *next;
};

struct node* reverse(struct node *head){
    struct node *prev=NULL,*current=head,*next=NULL;

    while(current!=NULL){
        next=current->next;
        current->next=prev;
        prev=current;
        current=next;
    }

    return prev;
}
void middle(struct node *head){
    struct node *slow=head,*fast=head;

    while(fast!=NULL && fast->next!=NULL){
        slow=slow->next;
        fast=fast->next->next;
    }

    printf("Middle = %d",slow->data);
}