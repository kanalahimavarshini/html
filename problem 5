struct node{
    int data;
    struct node *next;
};

void removeDuplicates(struct node *head){
    struct node *ptr1,*ptr2,*dup;

    ptr1=head;

    while(ptr1!=NULL && ptr1->next!=NULL){
        ptr2=ptr1;

        while(ptr2->next!=NULL){
            if(ptr1->data == ptr2->next->data){
                dup=ptr2->next;
                ptr2->next=ptr2->next->next;
                free(dup);
            }
            else
                ptr2=ptr2->next;
        }

        ptr1=ptr1->next;
    }
}
