struct node{
    int data;
    struct node *next;
};

struct node* merge(struct node* a, struct node* b){
    if(a==NULL) return b;
    if(b==NULL) return a;

    if(a->data < b->data){
        a->next = merge(a->next,b);
        return a;
    }
    else{
        b->next = merge(a,b->next);
        return b;
    }
}
