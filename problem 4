#include <stdio.h>

void quicksort(int arr[], int low, int high);
int partition(int arr[], int low, int high);

int main() {
    int arr[] = {10, 7, 8, 9, 1, 5};
    int n = 6;

    quicksort(arr, 0, n-1);

    printf("Sorted array: ");
    for(int i=0;i<n;i++)
        printf("%d ", arr[i]);

    return 0;
}

void quicksort(int arr[], int low, int high) {
    if(low < high) {
        int pi = partition(arr, low, high);

        quicksort(arr, low, pi-1);
        quicksort(arr, pi+1, high);
    }
}

int partition(int arr[], int low, int high) {
    int pivot = arr[high];
    int i = low - 1;
    int temp;

    for(int j = low; j < high; j++) {
        if(arr[j] < pivot) {
            i++;
            temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
        }
    }

    temp = arr[i+1];
    arr[i+1] = arr[high];
    arr[high] = temp;

    return i+1;
}
#include <stdio.h>

void merge(int arr[], int l, int m, int r);
void mergesort(int arr[], int l, int r);

int main() {
    int arr[] = {12, 11, 13, 5, 6, 7};
    int n = 6;

    mergesort(arr, 0, n-1);

    printf("Sorted array: ");
    for(int i=0;i<n;i++)
        printf("%d ", arr[i]);

    return 0;
}

void mergesort(int arr[], int l, int r) {
    if(l < r) {
        int m = (l + r) / 2;

        mergesort(arr, l, m);
        mergesort(arr, m+1, r);

        merge(arr, l, m, r);
    }
}

void merge(int arr[], int l, int m, int r) {

    int i=l, j=m+1, k=0;
    int temp[50];

    while(i<=m && j<=r){
        if(arr[i] < arr[j])
            temp[k++] = arr[i++];
        else
            temp[k++] = arr[j++];
    }

    while(i<=m)
        temp[k++] = arr[i++];

    while(j<=r)
        temp[k++] = arr[j++];

    for(i=l, k=0; i<=r; i++, k++)
        arr[i] = temp[k];
}
#include <stdio.h>

void quicksort(int *arr, int low, int high);
int partition(int *arr, int low, int high);

int main()
{
    int arr[] = {9, 4, 7, 3, 10, 5};
    int n = 6;

    quicksort(arr, 0, n - 1);

    printf("Sorted array: ");

    for(int i = 0; i < n; i++)
        printf("%d ", *(arr + i));

    return 0;
}

void quicksort(int *arr, int low, int high)
{
    if(low < high)
    {
        int pi = partition(arr, low, high);

        quicksort(arr, low, pi - 1);
        quicksort(arr, pi + 1, high);
    }
}

int partition(int *arr, int low, int high)
{
    int pivot = *(arr + high);
    int i = low - 1;
    int temp;

    for(int j = low; j < high; j++)
    {
        if(*(arr + j) < pivot)
        {
            i++;

            temp = *(arr + i);
            *(arr + i) = *(arr + j);
            *(arr + j) = temp;
        }
    }

    temp = *(arr + i + 1);
    *(arr + i + 1) = *(arr + high);
    *(arr + high) = temp;

    return i + 1;
}
#include <stdio.h>

int binarySearch(int *arr, int n, int key) {
    int low = 0, high = n - 1, mid;

    while (low <= high) {
        mid = (low + high) / 2;

        if (*(arr + mid) == key)
            return mid;
        else if (*(arr + mid) < key)
            low = mid + 1;
        else
            high = mid - 1;
    }

    return -1;
}

int main() {
    int arr[] = {10,20,30,40,50};
    int n = 5;
    int key = 30;

    int result = binarySearch(arr, n, key);

    if(result != -1)
        printf("Element found at index %d", result);
    else
        printf("Element not found");

    return 0;
}
#include <stdio.h>

int stack[5];
int *top = stack - 1;

void push(int x){
    if(top == stack + 4)
        printf("Stack Overflow\n");
    else{
        top++;
        *top = x;
    }
}

void display(){
    int *temp = stack;

    while(temp <= top){
        printf("%d ",*temp);
        temp++;
    }
}

int main(){
    push(10);
    push(20);
    push(30);

    display();
}
