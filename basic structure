<!DOCTYPE html>
<html>
<head>
  <title>Structured Table</title>
</head>
<body>
  <table border="1">
    <thead>
      <tr>
        <th>Item</th>
        <th>Price</th>
        <th>Quantity</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Apple</td>
        <td>$2</td>
        <td>3</td>
      </tr>
      <tr>
        <td>Mango</td>
        <td>$1</td>
        <td>5</td>
      </tr>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="2">Total</td>
        <td>$11</td>
      </tr>
    </tfoot>
  </table>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
  <title>Spanning Table</title>
</head>
<body>
  <table border="1">
    <tr>
      <th colspan="2">Fruits</th>
      <th rowspan="3">Total</th>
    </tr>
    <tr>
      <td>Apple</td>
      <td>3</td>
    </tr>
    <tr>
      <td>Mango</td>
      <td>5</td>
    </tr>
  </table>
</body>
</html>
