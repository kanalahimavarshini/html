#include <stdio.h>
#include <string.h>

int main(){
    char str[]="hello world";
    int n=strlen(str);

    for(int i=n-1;i>=0;i--)
        printf("%c",str[i]);
}
#include <stdio.h>

int main(){
    char str[]="I love programming";
    int max=0,count=0;

    for(int i=0;str[i];i++){
        if(str[i]!=' ')
            count++;
        else{
            if(count>max)
                max=count;
            count=0;
        }
    }

    if(count>max)
        max=count;

    printf("Max length = %d",max);
}
#include <stdio.h>

int main(){
    char a[]="listen", b[]="silent";
    int count[256]={0};

    for(int i=0;a[i];i++){
        count[a[i]]++;
        count[b[i]]--;
    }

    int flag=0;

    for(int i=0;i<256;i++){
        if(count[i]!=0)
            flag=1;
    }

    if(flag==0)
        printf("Anagram");
    else
        printf("Not Anagram");
}
<!DOCTYPE html>
<html>
<body>

<form onsubmit="return validate()">
  Name: <input type="text" id="name"><br><br>
  Email: <input type="text" id="email"><br><br>
  Password: <input type="password" id="pass"><br><br>
  <button type="submit">Submit</button>
</form>

<script>
function validate(){
  let name = document.getElementById("name").value;
  let email = document.getElementById("email").value;
  let pass = document.getElementById("pass").value;

  if(name == "" || email == "" || pass == ""){
    alert("All fields required");
    return false;
  }

  if(pass.length < 6){
    alert("Password must be 6+ characters");
    return false;
  }

  alert("Form Submitted");
  return true;
}
</script>

</body>
</html>
<!DOCTYPE html>
<html>
<body>

<h2 id="count">0</h2>
<button onclick="inc()">+</button>
<button onclick="dec()">-</button>

<script>
let c = 0;

function inc(){
  c++;
  document.getElementById("count").innerText = c;
}

function dec(){
  c--;
  document.getElementById("count").innerText = c;
}
</script>

</body>
</html>
<!DOCTYPE html>
<html>
<body>

<input type="text" id="task">
<button onclick="addTask()">Add</button>

<ul id="list"></ul>

<script>
function addTask(){
  let task = document.getElementById("task").value;

  let li = document.createElement("li");
  li.innerText = task;

  document.getElementById("list").appendChild(li);
}
</script>

</body>
</html>
<!DOCTYPE html>
<html>
<body>

<textarea id="text" onkeyup="countChar()"></textarea>
<p>Characters: <span id="count">0</span></p>

<script>
function countChar(){
  let text = document.getElementById("text").value;
  document.getElementById("count").innerText = text.length;
}
</script>

</body>
</html>
