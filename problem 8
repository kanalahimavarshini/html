#include <stdio.h>
#include <string.h>

int main(){
    char str[]="hello world";
    int n=strlen(str);

    for(int i=n-1;i>=0;i--)
        printf("%c",str[i]);
}
#include <stdio.h>

int main(){
    char str[]="I love programming";
    int max=0,count=0;

    for(int i=0;str[i];i++){
        if(str[i]!=' ')
            count++;
        else{
            if(count>max)
                max=count;
            count=0;
        }
    }

    if(count>max)
        max=count;

    printf("Max length = %d",max);
}
#include <stdio.h>

int main(){
    char a[]="listen", b[]="silent";
    int count[256]={0};

    for(int i=0;a[i];i++){
        count[a[i]]++;
        count[b[i]]--;
    }

    int flag=0;

    for(int i=0;i<256;i++){
        if(count[i]!=0)
            flag=1;
    }

    if(flag==0)
        printf("Anagram");
    else
        printf("Not Anagram");
}