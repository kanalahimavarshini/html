#include <stdio.h>

int main(){
    char str[]="I love programming";
    int max=0,count=0;

    for(int i=0;str[i];i++){
        if(str[i]!=' ')
            count++;
        else{
            if(count>max)
                max=count;
            count=0;
        }
    }

    if(count>max)
        max=count;

    printf("Max length = %d",max);
