#include <stdio.h>

int main(){
    int a[2][2]={{1,2},{3,4}};
    int b[2][2]={{5,6},{7,8}};
    int c[2][2];

    for(int i=0;i<2;i++){
        for(int j=0;j<2;j++){
            c[i][j]=a[i][j]+b[i][j];
            printf("%d ",c[i][j]);
        }
        printf("\n");
    }
}
#include <stdio.h>

int main(){
    int arr[5]={10,20,4,45,99};
    int largest=0,second=0;

    for(int i=0;i<5;i++){
        if(arr[i]>largest){
            second=largest;
            largest=arr[i];
        }
        else if(arr[i]>second && arr[i]!=largest)
            second=arr[i];
    }

    printf("Second Largest = %d",second);
}
#include <stdio.h>

int main() {
    int arr[5] = {1,2,3,4,5};
    int left = 0, right = 4, temp;

    while(left < right) {
        temp = arr[left];
        arr[left] = arr[right];
        arr[right] = temp;

        left++;
        right--;
    }

    for(int i=0;i<5;i++)
        printf("%d ",arr[i]);
}
#include <stdio.h>

int main() {
    int arr[5]={1,2,3,4,5};
    int sum=6;

    for(int i=0;i<5;i++){
        for(int j=i+1;j<5;j++){
            if(arr[i]+arr[j]==sum)
                printf("%d %d\n",arr[i],arr[j]);
        }
    }
}
#include <stdio.h>

int main(){
    int arr[5]={1,4,2,10,2};
    int max=0;

    for(int i=0;i<5;i++){
        int sum=0;
        for(int j=i;j<5;j++){
            sum+=arr[j];
            if(sum>max)
                max=sum;
        }
    }

    printf("Max Sum = %d",max);
}
#include <stdio.h>

int fact(int n){
    if(n==0)
        return 1;

    return n*fact(n-1);
}

int main(){
    printf("%d",fact(5));
}