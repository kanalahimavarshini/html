#include <stdio.h>

int main(){
    int arr[5]={10,20,4,45,99};
    int largest=0,second=0;

    for(int i=0;i<5;i++){
        if(arr[i]>largest){
            second=largest;
            largest=arr[i];
        }
        else if(arr[i]>second && arr[i]!=largest)
            second=arr[i];
    }

    printf("Second Largest = %d",second);
}
#include <stdio.h>

int main() {
    int arr[5] = {1,2,3,4,5};
    int left = 0, right = 4, temp;

    while(left < right) {
        temp = arr[left];
        arr[left] = arr[right];
        arr[right] = temp;

        left++;
        right--;
    }

    for(int i=0;i<5;i++)
        printf("%d ",arr[i]);
}
