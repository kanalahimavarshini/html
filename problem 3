int fib(int n){
    if(n<=1)
        return n;

    return fib(n-1)+fib(n-2);
}

int main(){
    for(int i=0;i<6;i++)
        printf("%d ",fib(i));
}
#include <stdio.h>

int stack[5], top=-1;

void push(int x){
    if(top==4)
        printf("Stack Overflow");
    else{
        top++;
        stack[top]=x;
    }
}

int main(){
    push(10);
    push(20);
    push(30);

    for(int i=0;i<=top;i++)
        printf("%d ",stack[i]);
}
#include <stdio.h>

int stack[5]={10,20,30};
int top=2;

void pop(){
    if(top==-1)
        printf("Stack Underflow");
    else
        top--;
}

int main(){
    pop();

    for(int i=0;i<=top;i++)
        printf("%d ",stack[i]);
}
#include <stdio.h>

int queue[5];
int front=0,rear=-1;

void enqueue(int x){
    rear++;
    queue[rear]=x;
}

int main(){
    enqueue(5);
    enqueue(10);

    for(int i=front;i<=rear;i++)
        printf("%d ",queue[i]);
}
#include <stdio.h>

void swap(int *a,int *b){
    int temp=*a;
    *a=*b;
    *b=temp;
}

int main(){
    int x=5,y=10;

    swap(&x,&y);

    printf("%d %d",x,y);
}
