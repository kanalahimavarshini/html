#include <stdio.h>

int main() {
    int n = 7, i, flag = 0;

    for(i = 2; i <= n/2; i++) {
        if(n % i == 0) {
            flag = 1;
            break;
        }
    }

    if(flag == 0)
        printf("Prime Number");
    else
        printf("Not Prime");

    return 0;
}
#include <stdio.h>

int main() {
    int a = 0, b = 1, c, i;

    printf("Fibonacci Series: ");

    for(i = 1; i <= 10; i++) {
        printf("%d ", a);
        c = a + b;
        a = b;
        b = c;
    }

    return 0;
}
#include <stdio.h>

int main() {
    int n = 121, temp, r, sum = 0;

    temp = n;

    while(n > 0) {
        r = n % 10;
        sum = sum * 10 + r;
        n = n / 10;
    }

    if(temp == sum)
        printf("Palindrome");
    else
        printf("Not Palindrome");

    return 0;
}
