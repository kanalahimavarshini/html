#include <stdio.h>

int main() {
    int arr[5] = {10, 25, 8, 40, 15};
    int i, max = arr[0];

    for(i = 1; i < 5; i++) {
        if(arr[i] > max) {
            max = arr[i];
        }
    }

    printf("Largest number = %d", max);
    return 0;
}
#include <stdio.h>

int main() {
    int arr[5] = {1,2,3,4,5};
    int i;

    printf("Reversed array: ");

    for(i = 4; i >= 0; i--) {
        printf("%d ", arr[i]);
    }

    return 0;
}
#include <stdio.h>

int main() {
    int n = 7, i, flag = 0;

    for(i = 2; i <= n/2; i++) {
        if(n % i == 0) {
            flag = 1;
            break;
        }
    }

    if(flag == 0)
        printf("Prime Number");
    else
        printf("Not Prime");

    return 0;
}