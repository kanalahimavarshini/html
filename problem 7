#include <stdio.h>

int main(){
    char str[]="abcabcbb";
    int max=0;

    for(int i=0;str[i];i++){
        int visited[256]={0};
        int len=0;

        for(int j=i;str[j];j++){
            if(visited[str[j]])
                break;

            visited[str[j]]=1;
            len++;

            if(len>max)
                max=len;
        }
    }

    printf("Length = %d",max);
}
#include <stdio.h>

void reverse(int arr[], int start, int end){
    while(start<end){
        int temp=arr[start];
        arr[start]=arr[end];
        arr[end]=temp;
        start++; end--;
    }
}

int main(){
    int arr[]={1,2,3,4,5,6,7};
    int n=7, k=3;

    reverse(arr,0,n-1);
    reverse(arr,0,k-1);
    reverse(arr,k,n-1);

    for(int i=0;i<n;i++)
        printf("%d ",arr[i]);
}