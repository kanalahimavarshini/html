#include <stdio.h>

int visited[5];

void dfs(int graph[5][5], int v){
    printf("%d ",v);
    visited[v]=1;

    for(int i=0;i<5;i++){
        if(graph[v][i]==1 && !visited[i])
            dfs(graph,i);
    }
}

