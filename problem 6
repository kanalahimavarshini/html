#include <stdio.h>

int fib(int n, int dp[]) {
    if (n <= 1)
        return n;

    if (dp[n] != -1)
        return dp[n];

    dp[n] = fib(n-1, dp) + fib(n-2, dp);
    return dp[n];
}

int main() {
    int n = 10;
    int dp[20];

    for(int i=0;i<20;i++)
        dp[i] = -1;

    printf("Fibonacci = %d", fib(n, dp));

    return 0;
}
